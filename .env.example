PORT=3001
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/zerodash-0g

# JWT Auth (shared with game client)
BROWSER_JWT_SECRET=your-jwt-secret-here

# ── 0G Storage ──────────────────────────────────────────────────────────────
ZG_INDEXER_RPC=https://indexer-storage-turbo.0g.ai

# ── 0G DA ────────────────────────────────────────────────────────────────────
ZG_DA_DISPERSER=disperser-testnet.0g.ai:51001

# ── 0G EVM Chain (chainId 16600 — PlayerSaveAnchor lives here) ──────────────
ZG_RPC_URL=https://evmrpc.0g.ai
ZG_CHAIN_ID=16600
# Set this AFTER running: npm run deploy:anchor
ZG_ANCHOR_CONTRACT_ADDRESS=0x_SET_AFTER_DEPLOY
# Backend operator wallet — becomes immutable backendOperator in the contract
ZG_PRIVATE_KEY=your-backend-operator-private-key

# ── 0G Compute anti-cheat (optional — skip if not set) ──────────────────────
ZG_COMPUTE_API_KEY=

# ── Master switch — set false to disable all 0G ops in local dev ─────────────
ZG_ENABLED=true

# ── Existing 0G Mainnet contracts (chainId 16661) ────────────────────────────
OG_MAINNET_RPC=https://evmrpc.0g.ai
PRIVATE_KEY=your-private-key-for-session-leaderboard-contracts
SESSION_CONTRACT_ADDRESS=0x9D8090A0D65370A9c653f71e605718F397D1B69C
LEADERBOARD_CONTRACT_ADDRESS=
