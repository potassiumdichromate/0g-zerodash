PORT=3001
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/zerodash-0g

# JWT Auth (shared with game client)
BROWSER_JWT_SECRET=your-jwt-secret-here

# ── 0G Mainnet (chainId 16661) ───────────────────────────────────────────────
# Used by: Storage uploads/downloads, Chain anchoring, Contract deployment
OG_MAINNET_RPC=https://evmrpc.0g.ai
OG_MAINNET_CHAIN_ID=16661

# 0G Storage indexer — mainnet node
ZG_INDEXER_RPC=https://indexer-storage-turbo-v2.0g.ai

# PlayerSaveAnchor contract — deploy on mainnet: npm run deploy:anchor
ZG_ANCHOR_CONTRACT_ADDRESS=0x_SET_AFTER_DEPLOY

# Backend operator wallet — signs storage uploads + anchorSave transactions
# This address becomes the immutable backendOperator in the contract
ZG_PRIVATE_KEY=your-backend-operator-private-key

# ── 0G DA — Testnet ONLY (DA not available on mainnet yet) ───────────────────
ZG_DA_DISPERSER=disperser-testnet.0g.ai:51001

# ── 0G Compute anti-cheat (mainnet API, optional) ────────────────────────────
# Leave blank to skip anti-cheat entirely
ZG_COMPUTE_API_KEY=

# ── Master switch — false disables all 0G ops without breaking anything else ──
ZG_ENABLED=true

# ── Existing 0G Mainnet contracts (chainId 16661) ────────────────────────────
PRIVATE_KEY=your-private-key-for-session-leaderboard-contracts
SESSION_CONTRACT_ADDRESS=0x9D8090A0D65370A9c653f71e605718F397D1B69C
LEADERBOARD_CONTRACT_ADDRESS=
